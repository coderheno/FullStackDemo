# MODULE 7 : COMPLETE LOGIN SYSTEM
# --------------------------------------------------

st.title("🚀 Module 7 : Complete Login System & Full Stack Workflow")

st.success("""
Learning Outcomes

✅ Understand Client-Server Architecture

✅ Connect Frontend with Backend

✅ Use Forms, Events and Objects Together

✅ Use JSON Data Exchange

✅ Use Fetch API

✅ Use Async/Await

✅ Understand Express.js Routes

✅ Understand Full Stack Workflow
""")

# --------------------------------------------------
# BIG PICTURE
# --------------------------------------------------

st.header("1️⃣ What Have We Learned So Far?")

st.markdown("""

```text
JavaScript Objects
        ↓
Forms
        ↓
Events
        ↓
JSON
        ↓
Async/Await
        ↓
Fetch API
        ↓
Navigator API
        ↓
Storage
        ↓
Login System

""")

st.info("""
The Login System is not a new concept.

It is simply an application that combines everything you have learned.
""")

# --------------------------------------------------
# LOGIN FORM
# --------------------------------------------------

st.header("2️⃣ Login Page")

st.code("""

<form id="loginForm">

<input type="text" id="username">

<input type="password" id="password">

<button>

Login

</button> </form>

""", language="html")

st.success("""
This is the User Interface (Frontend).
""")

# --------------------------------------------------
# STEP 1
# --------------------------------------------------

st.header("3️⃣ Step 1 : User Enters Data")

st.markdown("""

Username

↓

Password

↓

Login Button

""")

# --------------------------------------------------
# STEP 2
# --------------------------------------------------

st.header("4️⃣ Step 2 : Submit Event")

st.code("""

loginForm.addEventListener(

"submit",

function(event){

event.preventDefault();

}

);

""", language="javascript")

st.info("""
Submit Event is triggered when the user clicks Login.
""")

# --------------------------------------------------
# STEP 3
# --------------------------------------------------

st.header("5️⃣ Step 3 : Read Form Data")

st.code("""

const username =

document.getElementById("username").value;

const password =

document.getElementById("password").value;

""", language="javascript")

st.success("""
JavaScript reads user input.
""")

# --------------------------------------------------
# STEP 4
# --------------------------------------------------

st.header("6️⃣ Step 4 : Create Object")

st.code("""

const loginData = {

username,

password

};

""", language="javascript")

st.markdown("""

Form

↓

JavaScript Object

""")

# --------------------------------------------------
# STEP 5
# --------------------------------------------------

st.header("7️⃣ Step 5 : Convert to JSON")

st.code("""

JSON.stringify(

loginData

);

""", language="javascript")

st.markdown("""

{
 "username":"admin",
 "password":"1234"
}

""")

# --------------------------------------------------
# STEP 6
# --------------------------------------------------

st.header("8️⃣ Step 6 : Send Request")

st.code("""

const response =

await fetch(

"/login",

{

method:"POST",

headers:{

"Content-Type":"application/json"

},

body:JSON.stringify(loginData)

}

);

""", language="javascript")

st.success("""
Browser sends request to the server.
""")

# --------------------------------------------------
# CLIENT SERVER
# --------------------------------------------------

st.header("9️⃣ Client-Server Communication")

st.markdown("""

Browser

↓

Fetch API

↓

Express Server

↓

Response

↓

Browser

""")

# --------------------------------------------------
# STEP 7
# --------------------------------------------------

st.header("🔟 Express Receives Request")

st.code("""

app.post(

"/login",

(req,res)=>{

}

);

""", language="javascript")

st.success("""
Express listens for requests.
""")

# --------------------------------------------------
# STEP 8
# --------------------------------------------------

st.header("1️⃣1️⃣ Validate Credentials")

st.code("""

if(

username==="admin"

&&

password==="1234"

){

// Success

}

""", language="javascript")

st.info("""
Server checks user credentials.
""")

# --------------------------------------------------
# STEP 9
# --------------------------------------------------

st.header("1️⃣2️⃣ JSON Response")

st.code("""

res.json({

success:true,

message:"Login Successful"

});

""", language="javascript")

st.markdown("""

{
 "success":true,
 "message":"Login Successful"
}

""")

# --------------------------------------------------
# STEP 10
# --------------------------------------------------

st.header("1️⃣3️⃣ Browser Receives Response")

st.code("""

const data =

await response.json();

""", language="javascript")

st.success("""
JSON becomes a JavaScript Object again.
""")

# --------------------------------------------------
# STEP 11
# --------------------------------------------------

st.header("1️⃣4️⃣ Update User Interface")

st.code("""

if(data.success){

message.innerHTML =

"Login Successful";

}

""", language="javascript")

st.markdown("""

Response

↓

DOM Update

↓

Message Displayed

""")

# --------------------------------------------------
# COMPLETE FLOW
# --------------------------------------------------

st.header("1️⃣5️⃣ Complete Login Workflow")

st.markdown("""

User Opens Website

↓

Enters Username

↓

Enters Password

↓

Clicks Login

↓

Submit Event

↓

Create Object

↓

JSON

↓

Fetch API

↓

Express Server

↓

Validation

↓

JSON Response

↓

Response Received

↓

DOM Updated

↓

Success Message

""")

# --------------------------------------------------
# LOCAL STORAGE
# --------------------------------------------------

st.header("1️⃣6️⃣ Remember Logged-In User")

st.code("""

localStorage.setItem(

"username",

username

);

""", language="javascript")

st.success("""
Used for Remember Me functionality.
""")

# --------------------------------------------------
DASHBOARD
# --------------------------------------------------

st.header("1️⃣7️⃣ Dashboard Example")

st.code("""

const username =

localStorage.getItem(

"username"

);

""", language="javascript")

st.markdown("""

Welcome Admin

""")

