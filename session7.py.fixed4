"Choose Request Type",

[

    "GET",

    "POST",

    "PUT",

    "DELETE"

# ]

# )

if request_type == "GET":

    st.success("Used to Retrieve Data")

elif request_type == "POST":

    st.success("Used to Send Data")

elif request_type == "PUT":

    st.success("Used to Update Data")

elif request_type == "DELETE":

    st.success("Used to Delete Data")
