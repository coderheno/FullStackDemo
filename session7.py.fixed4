# --------------------------------------------------
COOKIES
# --------------------------------------------------

st.header("9️⃣ What are Cookies?")

st.markdown("""
Cookies store small pieces of information inside the browser.

Examples:

🍪 Remember Login

🍪 User Preferences

🍪 Shopping Cart

🍪 Language Settings
""")

st.code("""

document.cookie =

"username=admin";

""", language="javascript")

st.success("""
Cookies are stored in the browser.
""")

