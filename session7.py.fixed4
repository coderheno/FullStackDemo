QUIZ
# --------------------------------------------------

st.header("📝 Quick Quiz")

quiz = st.radio(

"Which keyword pauses execution until a Promise completes?",

[

    "pause",

    "stop",

    "await",

    "hold"

],

key="async_quiz"

# )

if quiz == "await":

    st.success("✅ Correct")
# --------------------------------------------------
# FULL STACK CONNECTION
# --------------------------------------------------

st.header("🚀 Why Is This Important?")

st.markdown("""

Future Topics Using Async/Await:

✅ Fetch API

✅ Express.js

✅ MongoDB

✅ React

✅ Next.js

✅ Authentication

✅ AI APIs

✅ Cloud Storage

""")

# --------------------------------------------------
# LOGIN SYSTEM CONNECTION
# --------------------------------------------------

st.header("🔑 Login System Workflow")

st.markdown("""

User Clicks Login

↓

Send Request

↓

Server Checks Credentials

↓

Wait

↓

Response Received

↓

Display Result

""")

st.success("""
This waiting period is handled using Async/Await.
""")

