# MINI QUIZ
# --------------------------------------------------

st.header("📝 Quick Quiz")

answer = st.radio(

"Which of the following is a JavaScript Object?",

[

    "let age = 20",

    "const student = {name:'John'}",

    "const names = ['A','B']",

    "console.log('Hello')"

# ]

# )

if answer == "const student = {name:'John'}":

    st.success("✅ Correct")
# --------------------------------------------------
    CONNECTION
# --------------------------------------------------

st.header("🚀 What's Next?")

st.info("""
Objects store data.

But where does the data come from?

👇

Forms

👇

Users enter data through forms.

In the next module, we will learn:

✅ JavaScript Forms

✅ Form Inputs

✅ Reading User Data

✅ Form Validation

which eventually leads us to Login Systems and Full Stack Development.
""")
# --------------------------------------------------
# NESTED OBJECTS
# --------------------------------------------------

st.header("9️⃣ Nested Objects")

st.markdown("""
Objects can contain other objects.

This is called a Nested Object.

Real-world Example:

A Student has an Address.
""")

st.code("""
const student = {

    regno : "2472101",

    name : "John",

    address : {

        city : "Bangalore",

        state : "Karnataka",

        country : "India"

    }

};
""", language="javascript")

st.markdown("""
### Visual Representation

```text
Student
│
├── regno
├── name
│
└── address
     │
     ├── city
     ├── state
     └── country

""")

st.code("""
console.log(student.address.city);

console.log(student.address.state);
""", language="javascript")

st.success("""
Output

Bangalore

Karnataka
""")

# --------------------------------------------------
# INTERACTIVE NESTED OBJECT
# --------------------------------------------------

st.subheader("Nested Object Generator")

city = st.text_input("City")

state = st.text_input("State")

country = st.text_input("Country")

if st.button("Generate Nested Object"):

    student_obj = {

        "name": "Student",

        "address": {

            "city": city,

            "state": state,

#         "country": country

#     }

# }

st.json(student_obj)
# --------------------------------------------------
# ARRAY OF OBJECTS
# --------------------------------------------------

st.header("🔟 Array of Objects")

st.markdown("""
Most real-world applications store multiple records.

For example:

Student List
Product List
Employee List

These are represented using Arrays of Objects.
""")

st.code("""
const students = [

{
    regno : "101",
    name : "John"
},

{
    regno : "102",
    name : "Mary"
},

{
    regno : "103",
    name : "David"
}

];
""", language="javascript")

st.info("""
Think of this as a Database Table.
""")

st.markdown("""

Students

Row 1 → Object

Row 2 → Object

Row 3 → Object

""")

st.code("""
console.log(students[0].name);

console.log(students[1].name);
""", language="javascript")

st.success("""
Output

John

Mary
""")

# --------------------------------------------------
# DATABASE SIMULATION
# --------------------------------------------------

st.header("1️⃣1️⃣ Student Database Simulation")

student_data = [

{
    "regno":"101",
    "name":"John",
#     "course":"BCA"
},

{
    "regno":"102",
    "name":"Mary",
#     "course":"BSc"
},

{
    "regno":"103",
    "name":"David",
#     "course":"MCA"
# }

# ]

st.dataframe(student_data)

st.success("""
In real applications,

Data from databases is usually received in this format.
""")

# --------------------------------------------------
# OBJECT METHODS
# --------------------------------------------------

st.header("1️⃣2️⃣ Object Methods")

st.markdown("""
Objects can also contain Functions.

These functions are called Methods.
""")

st.code("""
const student = {

name : "John",

greet : function(){

    return "Welcome";

}

};

console.log(student.greet());
""", language="javascript")

st.success("""
Output

Welcome
""")

# --------------------------------------------------
# REAL WORLD CONNECTION
# --------------------------------------------------

st.header("1️⃣3️⃣ Real World Mapping")

mapping = {

"Application":[
    "Amazon",
    "Netflix",
    "Instagram",
    "Student Portal",
    "Hospital System"
],

"Object Example":[
    "Product",
    "Movie",
    "User",
    "Student",
    "Patient"
# ]

# }

st.table(mapping)

# --------------------------------------------------
# JSON INTRODUCTION
# --------------------------------------------------

st.header("1️⃣4️⃣ Introduction to JSON")

st.markdown("""
Objects are used inside JavaScript.

But how do we send data over the Internet?

Answer:

JSON

(JavaScript Object Notation)
""")

st.code("""
const student = {

name : "John",

course : "BCA"

};
""", language="javascript")

st.markdown("### Equivalent JSON")

st.code("""
{
"name":"John",
"course":"BCA"
}
""", language="json")

st.info("""
JSON is the standard format used in APIs,
Servers,
Databases,
and Full Stack Applications.
""")

# --------------------------------------------------
# WHY JSON?
# --------------------------------------------------

st.header("1️⃣5️⃣ Why JSON?")

st.markdown("""

Browser
    ↓
JSON
    ↓
Server
    ↓
JSON
    ↓
Browser

""")

st.success("""
JSON acts as a common language between applications.
""")

