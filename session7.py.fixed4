""")

# --------------------------------------------------
# INTRODUCTION
# --------------------------------------------------

st.header("1️⃣ What is Navigator API?")

st.markdown("""
Navigator API allows JavaScript to interact with browser features.

Using Navigator API we can:

📍 Get User Location

📋 Access Clipboard

📶 Detect Internet Status

🖥 Identify Browser

📱 Identify Device
""")

st.markdown("""

```text
Browser

↓

Navigator Object

↓

Browser Features

""")

# --------------------------------------------------
# NAVIGATOR OBJECT
# --------------------------------------------------

st.header("2️⃣ Navigator Object")

st.code("""

console.log(navigator);

""", language="javascript")

st.info("""
Navigator contains information about:

Browser

Operating System

Internet Status

Location

Language

Device Information
""")

# --------------------------------------------------
# USER AGENT
# --------------------------------------------------

st.header("3️⃣ User Agent")

st.markdown("""
User Agent identifies the browser and operating system.
""")

st.code("""

console.log(

navigator.userAgent

);

""", language="javascript")

st.success("""
Examples:

Chrome

Safari

Firefox

Edge
""")

# --------------------------------------------------
LANGUAGE
# --------------------------------------------------

st.header("4️⃣ Browser Language")

st.code("""

console.log(

navigator.language

);

""", language="javascript")

st.success("""
Example:

en-US

en-IN

ta-IN
""")

# --------------------------------------------------
# ONLINE STATUS
# --------------------------------------------------

st.header("5️⃣ Online Status")

st.markdown("""
Detect whether the device is connected to the Internet.
""")

st.code("""

console.log(

navigator.onLine

);

""", language="javascript")

st.success("""
true

false
""")

internet = st.radio(

"Simulated Internet Status",

[

    "Connected",

    "Disconnected"

# ]

# )

if internet == "Connected":

    st.success("🌐 Internet Available")

else:

st.error("❌ Internet Not Available")
# --------------------------------------------------
GEOLOCATION
# --------------------------------------------------

st.header("6️⃣ Geolocation API")

st.markdown("""
Used to obtain the user's current location.

Examples:

🚕 Uber

🛵 Swiggy

📦 Delivery Apps

🏥 Emergency Services
""")

st.code("""

navigator.geolocation
.getCurrentPosition(

(position)=>{

console.log(

position.coords.latitude

);

console.log(

position.coords.longitude

);

}

);

""", language="javascript")

st.markdown("""

User

↓

Allow Location

↓

Latitude

↓

Longitude

""")

