# --------------------------------------------------
# MODULE 3 : EVENTS & EVENT HANDLING
# --------------------------------------------------

st.title("⚡ Module 3 : Events & Event Handling")

st.success("""
Learning Outcomes

✅ Understand Events

✅ Understand Event Handling

✅ Work with Click Events

✅ Work with Input Events

✅ Work with Change Events

✅ Work with Mouse Events

✅ Work with Keyboard Events

✅ Work with Submit Events

✅ Connect Events with Real Applications
""")

# --------------------------------------------------
# INTRODUCTION
# --------------------------------------------------

st.header("1️⃣ What is an Event?")

st.markdown("""
An Event is an action that occurs inside a webpage.

Events are usually triggered by:

👨 User Actions

⌨ Keyboard Actions

🖱 Mouse Actions

📋 Form Submission

📱 Device Actions

Without Events, web pages cannot interact with users.
""")

st.markdown("""

```text
User Action

↓

Event Occurs

↓

JavaScript Executes

↓

Output Produced

""")

# --------------------------------------------------
# REAL WORLD EXAMPLES
# --------------------------------------------------

st.header("2️⃣ Real World Examples")

events_table = {

"Scenario":[

    "Click Login",

    "Select Course",

    "Type Name",

    "Upload File",

    "Submit Form",

    "Hover Button"

],

"Event":[

    "click",

    "change",

    "input",

    "change",

    "submit",

    "mouseover"

# ]

# }

st.table(events_table)

# --------------------------------------------------
# CLICK EVENT
# --------------------------------------------------

st.header("3️⃣ Click Event")

st.markdown("""
The Click Event occurs when the user clicks a button or element.
""")

st.code("""

button.addEventListener(

"click",

function(){

alert("Button Clicked");

}

);

""", language="javascript")

if st.button("Demo Click Event"):

    st.success("Button Click Event Triggered")
# --------------------------------------------------
# INPUT EVENT
# --------------------------------------------------

st.header("4️⃣ Input Event")

st.markdown("""
The Input Event occurs whenever the user types something.
""")

st.code("""

input.addEventListener(

"input",

function(){

console.log(this.value);

}

);

""", language="javascript")

typing = st.text_input("Type Something")

if typing:

    st.info(f"You Typed : {typing}")
# --------------------------------------------------
# CHANGE EVENT
# --------------------------------------------------

st.header("5️⃣ Change Event")

st.markdown("""
Triggered when a value changes.
""")

st.code("""

select.addEventListener(

"change",

function(){

alert(this.value);

}

);

""", language="javascript")

course = st.selectbox(

"Select Course",

[

    "BCA",

    "BSc",

    "MCA",

    "MBA"

# ]

# )

st.success(f"Selected : {course}")

# --------------------------------------------------
# MOUSE EVENTS
# --------------------------------------------------

st.header("6️⃣ Mouse Events")

st.markdown("""
Common Mouse Events:

✅ mouseover

✅ mouseout

✅ mousemove

✅ mousedown

✅ mouseup
""")

st.code("""

element.addEventListener(

"mouseover",

function(){

console.log("Mouse Over");

}

);

""", language="javascript")

st.info("""
Move your mouse over buttons,
cards,
images,
menus

to trigger mouse events.
""")

# --------------------------------------------------
# KEYBOARD EVENTS
# --------------------------------------------------

st.header("7️⃣ Keyboard Events")

st.markdown("""
Keyboard Events occur when keys are pressed.
""")

keyboard_table = {

"Event":[

    "keydown",

    "keyup",

    "keypress"

],

"Purpose":[

    "Key Pressed",

    "Key Released",

    "Character Typed"

# ]

# }

st.table(keyboard_table)

st.code("""

document.addEventListener(

"keydown",

function(event){

console.log(event.key);

}

);

""", language="javascript")

# --------------------------------------------------
# DOUBLE CLICK
# --------------------------------------------------

st.header("8️⃣ Double Click Event")

st.code("""

element.addEventListener(

"dblclick",

function(){

alert("Double Clicked");

}

);

""", language="javascript")

st.info("""
Commonly used in:

📁 File Explorer

🖼 Image Viewers

📊 Dashboards
""")

# --------------------------------------------------
# FOCUS EVENT
# --------------------------------------------------

st.header("9️⃣ Focus Event")

st.markdown("""
Triggered when a user clicks inside an input field.
""")

st.code("""

input.addEventListener(

"focus",

function(){

this.style.background="yellow";

}

);

""", language="javascript")

# --------------------------------------------------
# BLUR EVENT
# --------------------------------------------------

st.header("🔟 Blur Event")

st.markdown("""
Triggered when an input loses focus.
""")

st.code("""

input.addEventListener(

"blur",

function(){

console.log("Focus Lost");

}

);

""", language="javascript")

# --------------------------------------------------
# SUBMIT EVENT
# --------------------------------------------------

st.header("1️⃣1️⃣ Submit Event")

st.markdown("""
Most important event for forms.

Used in:

✅ Login

✅ Registration

✅ Booking

✅ Payment

✅ Service Requests
""")

st.code("""

form.addEventListener(

"submit",

function(event){

event.preventDefault();

}

);

""", language="javascript")

st.success("""
Submit Event is the foundation of Login Systems.
""")

# --------------------------------------------------
# EVENT FLOW
# --------------------------------------------------

st.header("1️⃣2️⃣ Event Flow")

st.markdown("""

User Clicks Button

↓

Click Event

↓

JavaScript Function Executes

↓

Output Displayed

""")

# --------------------------------------------------
# DOMAIN EXAMPLES
# --------------------------------------------------

st.header("1️⃣3️⃣ Event Usage in Real Applications")

domain_table = {

"Application":[

    "E-Commerce",

    "Hospital",

    "College",

    "Travel",

    "CRM"

],

"Event":[

    "Add to Cart",

    "Book Appointment",

    "Submit Assignment",

    "Book Ticket",

    "Create Ticket"

# ]

# }

st.table(domain_table)

