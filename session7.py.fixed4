# --------------------------------------------------
# MODULE 2 : JAVASCRIPT FORMS
# --------------------------------------------------

st.title("📝 Module 2 : JavaScript Forms")

st.success("""
Learning Outcomes

✅ Understand HTML Forms

✅ Understand Form Elements

✅ Read User Input using JavaScript

✅ Validate Form Data

✅ Build Interactive Forms

✅ Connect Forms with Objects
""")

# --------------------------------------------------
# INTRODUCTION
# --------------------------------------------------

st.header("1️⃣ What is a Form?")

st.markdown("""
A Form is used to collect information from users.

Examples:

🎓 Student Registration

🛒 Product Order

🏥 Patient Registration

✈️ Travel Booking

📅 Event Registration

🔑 Login Page
""")

st.info("""
Without forms, websites become read-only.

Forms make websites interactive.
""")

# --------------------------------------------------
# REAL WORLD ANALOGY
# --------------------------------------------------

st.header("2️⃣ Real World Analogy")

st.markdown("""
Imagine a College Admission Form.

Student enters:

- Name
- Register Number
- Email
- Mobile Number

The information is then processed and stored.

The same process happens in web applications.
""")

st.markdown("""
```text
User
   ↓
Form
   ↓
JavaScript
   ↓
Validation
   ↓
Processing

""")

# --------------------------------------------------
# FORM ELEMENTS
# --------------------------------------------------

st.header("3️⃣ Common Form Elements")

st.markdown("""
HTML provides various form controls.
""")

form_elements = {

"Element":[

    "Text Box",

    "Password",

    "Radio Button",

    "Checkbox",

    "Dropdown",

    "Text Area",

    "Button"

],

"Purpose":[

    "Enter text",

    "Enter password",

    "Single choice",

    "Multiple choice",

    "Select option",

    "Large text",

    "Perform action"

# ]

# }

st.table(form_elements)

# --------------------------------------------------
# TEXT INPUT
# --------------------------------------------------

st.header("4️⃣ Text Input")

st.code("""
<input type="text" id="name" placeholder="Enter Name">
""", language="html")

name_demo = st.text_input("Demo : Enter Your Name")

if name_demo:

    st.success(f"Hello {name_demo}")
# --------------------------------------------------
# PASSWORD FIELD
# --------------------------------------------------

st.header("5️⃣ Password Input")

st.code("""
<input type="password" id="password">
""", language="html")

pwd = st.text_input(

"Demo Password",

type="password"

# )

if pwd:

    st.info("Password Entered Successfully")
# --------------------------------------------------
# RADIO BUTTON
# --------------------------------------------------

st.header("6️⃣ Radio Buttons")

st.code("""
<input type="radio">
""", language="html")

gender = st.radio(

"Select Gender",

[

    "Male",

    "Female",

    "Other"

# ]

# )

st.success(f"Selected : {gender}")

# --------------------------------------------------
CHECKBOX
# --------------------------------------------------

st.header("7️⃣ Checkboxes")

agree = st.checkbox(

"I Agree to Terms and Conditions"

# )

if agree:

    st.success("Terms Accepted")
# --------------------------------------------------
    DROPDOWN
# --------------------------------------------------

st.header("8️⃣ Dropdown")

course = st.selectbox(

"Select Course",

[

    "BCA",

    "BSc",

    "MCA",

    "MBA"

# ]

# )

st.success(course)

# --------------------------------------------------
# TEXT AREA
# --------------------------------------------------

st.header("9️⃣ Text Area")

feedback = st.text_area(

"Feedback"

# )

if feedback:

    st.info(feedback)
# --------------------------------------------------
    BUTTONS
# --------------------------------------------------

st.header("🔟 Buttons")

st.code("""
<button>

Submit

</button> """, language="html")

if st.button("Click Me"):

    st.success("Button Clicked")
# --------------------------------------------------
# WHY FORMS?
# --------------------------------------------------

st.header("1️⃣1️⃣ Why Do We Need Forms?")

st.markdown("""
Forms allow us to:

✅ Collect Data

✅ Validate Data

✅ Store Data

✅ Send Data to Servers

✅ Create User Accounts

✅ Process Transactions
""")

# --------------------------------------------------
# FORM TO OBJECT
# --------------------------------------------------

st.header("1️⃣2️⃣ Forms + Objects")

st.markdown("""
User enters data through a form.

JavaScript converts the data into an Object.
""")

st.code("""
const student = {

name : name,

email : email,

course : course

};
""", language="javascript")

st.markdown("""

Form
   ↓
JavaScript
   ↓
Object

""")

# --------------------------------------------------
# INTERACTIVE FORM
# --------------------------------------------------

st.header("1️⃣3️⃣ Student Registration Form")

student_name = st.text_input(

"Student Name",

key="student_name"

# )

student_email = st.text_input(

"Email",

key="student_email"

# )

student_course = st.selectbox(

"Course",

[

    "BCA",

    "BSc",

    "MCA"

],

key="student_course"

# )

if st.button("Generate Student Object"):

    student_obj = {

        "name": student_name,

        "email": student_email,

#     "course": student_course

# }

st.json(student_obj)
