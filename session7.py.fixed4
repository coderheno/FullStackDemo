import streamlit as st
import json

# --------------------------------------------------
# MODULE 1 : JAVASCRIPT OBJECTS
# --------------------------------------------------

st.title("📦 Module 1 : JavaScript Objects")

st.success("""
Learning Outcomes

✅ Understand JavaScript Objects

✅ Create Objects

✅ Access Object Properties

✅ Add and Update Properties

✅ Understand Real-world Applications

✅ Connect Objects with Forms and JSON
""")

# --------------------------------------------------
# INTRODUCTION
# --------------------------------------------------

st.header("1️⃣ Why Do We Need Objects?")

st.markdown("""
Imagine a student.

A student has:

- Register Number
- Name
- Course
- Email
- Mobile

Can we store all this information in a single variable?

❌ No

Instead, JavaScript provides **Objects**.

Objects help us group related information together.
""")

st.info("""
Real-world Examples

👨 Student

📦 Product

👩 Employee

🎬 Movie

📚 Course

🏥 Patient
""")

# --------------------------------------------------
# OBJECT CONCEPT
# --------------------------------------------------

st.header("2️⃣ Understanding Objects")

st.markdown("""
A JavaScript Object is a collection of key-value pairs.

General Syntax:
""")

st.code("""
const objectName = {

    key1 : value1,

    key2 : value2,

    key3 : value3

};
""", language="javascript")

st.subheader("Student Object Example")

st.code("""
const student = {

    regno : "2472101",

    name : "John",

    course : "BCA"

};
""", language="javascript")

st.success("""
Object = Student

Keys = regno, name, course

Values = 2472101, John, BCA
""")

# --------------------------------------------------
# VISUAL EXPLANATION
# --------------------------------------------------

st.header("3️⃣ Visual Representation")

st.markdown("""
```text
Student Object

├── regno : 2472101

├── name : John

└── course : BCA

""")

# --------------------------------------------------
# INTERACTIVE DEMO
# --------------------------------------------------

st.header("4️⃣ Interactive Object Generator")

name = st.text_input("Student Name")

regno = st.text_input("Register Number")

course = st.text_input("Course")

if st.button("Generate Object"):

    student = {

        "regno": regno,

        "name": name,

#     "course": course

# }

st.subheader("Generated Object")

st.json(student)
# --------------------------------------------------
# ACCESSING PROPERTIES
# --------------------------------------------------

st.header("5️⃣ Accessing Object Properties")

st.markdown("""
Properties can be accessed using:

Dot Notation
Bracket Notation
""")

st.code("""
const student = {

name : "John",

course : "BCA"

};

console.log(student.name);

console.log(student["course"]);
""", language="javascript")

st.success("""
Output

John

BCA
""")

# --------------------------------------------------
# ADDING PROPERTIES
# --------------------------------------------------

st.header("6️⃣ Adding New Properties")

st.code("""
student.age = 21;

student.email = "john@gmail.com";
""", language="javascript")

st.info("""
New properties can be added at any time.
""")

# --------------------------------------------------
# UPDATING PROPERTIES
# --------------------------------------------------

st.header("7️⃣ Updating Properties")

st.code("""
student.name = "Mary";
""", language="javascript")

st.success("""
Before

John

After

Mary
""")

# --------------------------------------------------
# DELETING PROPERTIES
# --------------------------------------------------

st.header("8️⃣ Deleting Properties")

st.code("""
delete student.email;
""", language="javascript")

st.warning("""
The property will be permanently removed.
""")

# --------------------------------------------------
ACTIVITY
# --------------------------------------------------

st.header("🎯 Classroom Activity")

st.markdown("""
Create Objects for:

Employee
Product
Movie
Library Book
Hospital Patient

Identify:

Object Name
Keys
Values
""")
