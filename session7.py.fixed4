# MINI CHALLENGE
# --------------------------------------------------

st.header("🏆 Mini Challenge")

st.markdown("""
Create a Promise that simulates:

📦 Package Delivery

Wait for 5 seconds

Then display:

"Package Delivered Successfully"
""")

